version: "3.8"

# Traefik 3.0 — reverse proxy do {{NETWORK_NAME}}.
#
# Dashboard em modo "internal" (porta 8080 NAO exposta na web).
# Pra ver dashboard: docker service exec ou ssh tunnel. Habilitar
# dashboard publico requer basic auth com bcrypt; preferi nao expor
# por default pra evitar superficie de ataque.

services:
  traefik:
    image: traefik:v3.0
    command:
      - --api.dashboard=true
      - --api.insecure=false
      - --providers.swarm=true
      - --providers.swarm.exposedByDefault=false
      - --providers.swarm.network={{NETWORK_NAME}}
      - --entrypoints.web.address=:80
      - --entrypoints.web.http.redirections.entryPoint.to=websecure
      - --entrypoints.web.http.redirections.entryPoint.scheme=https
      - --entrypoints.websecure.address=:443
      - --certificatesresolvers.letsencrypt.acme.email={{TRAEFIK_LE_EMAIL}}
      - --certificatesresolvers.letsencrypt.acme.storage=/letsencrypt/acme.json
      - --certificatesresolvers.letsencrypt.acme.tlschallenge=true
      - --log.level=INFO
      - --accesslog=true
    ports:
      - target: 80
        published: 80
        mode: host
      - target: 443
        published: 443
        mode: host
    volumes:
      - /var/run/docker.sock:/var/run/docker.sock:ro
      - traefik-letsencrypt:/letsencrypt
    networks:
      - {{NETWORK_NAME}}
    deploy:
      mode: replicated
      replicas: 1
      placement:
        constraints:
          - node.role == manager
      labels:
        # O dashboard fica disponivel internamente para outras stacks
        # poderem registrar routers via labels. Nao expomos roteamento
        # publico do api@internal aqui (TRAEFIK_DOMAIN reservado pra
        # futura habilitacao via basic auth hash).
        - traefik.enable=false

volumes:
  traefik-letsencrypt:
    driver: local

networks:
  {{NETWORK_NAME}}:
    external: true
