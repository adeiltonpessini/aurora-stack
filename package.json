{
  "name": "@aurorabr/stack",
  "version": "0.1.0-alpha.3",
  "description": "Transforme qualquer Linux em uma infraestrutura inteligente — CLI de provisionamento Docker Swarm com IA conversacional.",
  "type": "module",
  "bin": {
    "aurora": "./bin/aurora.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run lint && npm test && npm run build"
  },
  "keywords": ["aurora", "docker", "swarm", "cli", "self-hosted", "devops", "homelab", "lgpd"],
  "author": "Adeilton Pessini",
  "license": "SEE LICENSE IN LICENSE",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/adeiltonpessini/aurora-stack.git"
  },
  "homepage": "https://stack.aurora-mcp.com",
  "engines": {
    "node": ">=20.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "bin",
    "setup",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "dependencies": {
    "@clack/prompts": "^0.7.0",
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "js-yaml": "^4.1.0",
    "ora": "^8.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.0.0",
    "tsup": "^8.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
